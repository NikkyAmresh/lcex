{
  "name": "leetcode-practice",
  "displayName": "LeetCode Practice — Problems, Study Plans & Interview Mode",
  "description": "Solve LeetCode problems in VS Code. Browse problems, study plans (Top Interview 150, Blind 75), and Question of the Day. Generate TypeScript / JavaScript / Python / C++ / Java templates, run examples inline, track XP & streaks, and run timed mock interviews.",
  "version": "0.7.4",
  "publisher": "nikkyamresh",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Education",
    "Snippets",
    "Programming Languages",
    "Other"
  ],
  "icon": "icons/icon.png",
  "activationEvents": [
    "onUri",
    "onWebviewPanel:leetcodeProblem",
    "workspaceContains:**/.leetcode"
  ],
  "main": "./out/extension.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/NikkyAmresh/lcex"
  },
  "bugs": {
    "url": "https://github.com/NikkyAmresh/lcex/issues"
  },
  "homepage": "https://github.com/NikkyAmresh/lcex#readme",
  "license": "MIT",
  "galleryBanner": {
    "color": "#1e1e2e",
    "theme": "dark"
  },
  "keywords": [
    "leetcode",
    "leet code",
    "leetcode practice",
    "leetcode problems",
    "leetcode solutions",
    "practice",
    "algorithm",
    "algorithms",
    "data structures",
    "dsa",
    "coding",
    "coding interview",
    "interview",
    "interview prep",
    "mock interview",
    "typescript",
    "javascript",
    "python",
    "cpp",
    "c++",
    "java",
    "study-plan",
    "top interview 150",
    "blind 75",
    "question of the day",
    "qotd"
  ],
  "contributes": {
    "commands": [
      {
        "command": "leetcode-practice.openProblem",
        "title": "LeetCode: Open/Create Problem",
        "category": "LeetCode"
      },
      {
        "command": "leetcode-practice.openQotd",
        "title": "LeetCode: Open Question of the Day",
        "category": "LeetCode"
      },
      {
        "command": "leetcode-practice.runExamples",
        "title": "LeetCode: Run Examples",
        "category": "LeetCode"
      },
      {
        "command": "leetcode-practice.openNextBugReview",
        "title": "LeetCode: Open Next Bug Review",
        "category": "LeetCode"
      },
      {
        "command": "leetcode-practice.fuzzVsBruteForce",
        "title": "LeetCode: Fuzz vs Brute Force",
        "category": "LeetCode"
      },
      {
        "command": "leetcode-practice.measureComplexity",
        "title": "LeetCode: Measure Complexity (Empirical)",
        "category": "LeetCode"
      },
      {
        "command": "leetcode-practice.visualizeRecursion",
        "title": "LeetCode: Visualize Recursion Call Tree",
        "category": "LeetCode"
      },
      {
        "command": "leetcode-practice.visualizeIterative",
        "title": "LeetCode: Visualize Iterative Traversal",
        "category": "LeetCode"
      },
      {
        "command": "leetcode-practice.clearInlineDecorations",
        "title": "LeetCode: Clear Inline Decorations",
        "category": "LeetCode"
      },
      {
        "command": "leetcode-practice.runAdversarialTests",
        "title": "LeetCode: Surface Adversarial Edge Cases",
        "category": "LeetCode"
      },
      {
        "command": "leetcode-practice.complexityBudget",
        "title": "LeetCode: Show Complexity Budget vs. Estimate",
        "category": "LeetCode"
      },
      {
        "command": "leetcode-practice.lint",
