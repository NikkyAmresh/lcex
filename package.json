{
  "name": "leetcode-practice",
  "displayName": "LeetCode Practice",
  "description": "Practice LeetCode problems in VS Code: generate TypeScript templates with example test cases, run examples with ts-node, browse problems & study plans, and track your progress. Sign in to sync with your LeetCode account.",
  "version": "0.1.0",
  "publisher": "lcex",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Programming Languages",
    "Snippets"
  ],
  "icon": "icons/logo-dark.png",
  "activationEvents": [
    "onUri",
    "workspaceContains:**/.leetcode",
    "onStartupFinished",
    "onCustomEditor:leetcode-practice.configEditor",
    "onCustomEditor:leetcode-practice.lcInterviewEditor",
    "onCustomEditor:leetcode-practice.lcInterviewReportEditor",
    "onCommand:leetcode-practice.openProblem",
    "onCommand:leetcode-practice.openQotd",
    "onCommand:leetcode-practice.runExamples",
    "onCommand:leetcode-practice.runInTerminal",
    "onCommand:leetcode-practice.signIn",
    "onCommand:leetcode-practice.signOut",
    "onCommand:leetcode-practice.refreshProblems",
    "onCommand:leetcode-practice.refreshQotd",
    "onCommand:leetcode-practice.refreshStatsData",
    "onCommand:leetcode-practice.switchStudyPlan",
    "onCommand:leetcode-practice.switchProblemList",
    "onCommand:leetcode-practice.markAsSolved",
    "onCommand:leetcode-practice.markAsAttempting",
    "onCommand:leetcode-practice.clearProblemStatus",
    "onCommand:leetcode-practice.agentMakeRunnable",
    "onCommand:leetcode-practice.agentHint",
    "onCommand:leetcode-practice.agentExplainCode",
    "onCommand:leetcode-practice.focusModeEnter",
    "onCommand:leetcode-practice.focusModeExit",
    "onCommand:leetcode-practice.setDailyGoal",
    "onCommand:leetcode-practice.interviewModeStart",
    "onCommand:leetcode-practice.interviewModeStop",
    "onCommand:leetcode-practice.interviewGenerateWithAi",
    "onCommand:leetcode-practice.openLcInterviewReportFile",
    "onView:leetcode-practice.problemsView",
    "onView:leetcode-practice.topInterview150View",
    "onView:leetcode-practice.problemListsView",
    "onView:leetcode-practice.qotdView"
  ],
  "main": "./out/extension.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/lcex/leetcode-practice"
  },
  "license": "MIT",
  "keywords": [
    "leetcode",
    "practice",
    "algorithm",
    "coding",
    "interview",
    "typescript",
    "ts-node",
    "study-plan",
    "vscode",
    "extension"
  ],
  "contributes": {
    "commands": [
      {
        "command": "leetcode-practice.openProblem",
        "title": "LeetCode: Open/Create Problem",
        "category": "LeetCode"
      },
      {
        "command": "leetcode-practice.openQotd",
        "title": "LeetCode: Open Question of the Day",
        "category": "LeetCode"
      },
      {
        "command": "leetcode-practice.runExamples",
        "title": "LeetCode: Run Examples",
        "category": "LeetCode"
      },
      {
        "command": "leetcode-practice.runInTerminal",
        "title": "LeetCode: Run in Terminal (ts-node)",
        "category": "LeetCode"
      },
      {
        "command": "leetcode-practice.signIn",
        "title": "LeetCode: Sign In",
        "category": "LeetCode"
      },
      {
        "command": "leetcode-practice.signOut",
        "title": "LeetCode: Sign Out",
        "category": "LeetCode"
      },
      {
        "command": "leetcode-practice.refreshProblems",
        "title": "LeetCode: Refresh Problems"
      },
      {
        "command": "leetcode-practice.refreshQotd",
        "title": "LeetCode: Refresh Question of the Day"
      },
      {
        "command": "leetcode-practice.markAsSolved",
        "title": "Mark as Solved"
      },
      {
        "command": "leetcode-practice.markAsAttempting",
        "title": "Mark as Attempting"
      },
      {
        "command": "leetcode-practice.clearProblemStatus",
        "title": "Clear Status"
      },
      {
        "command": "leetcode-practice.filterByDifficulty",
        "title": "LeetCode: Filter by Difficulty"
      },
      {
        "command": "leetcode-practice.searchProblems",
        "title": "LeetCode: Search Problems"
      },
      {
        "command": "leetcode-practice.openRandomProblem",
        "title": "LeetCode: Open Random Problem"
      },
      {
        "command": "leetcode-practice.viewStats",
        "title": "LeetCode: View Stats"
      },
      {
        "command": "leetcode-practice.refreshStatsData",
        "title": "LeetCode: Refresh Stats Data",
        "category": "LeetCode"
      },
      {
        "command": "leetcode-practice.applyTheme",
        "title": "LeetCode: Apply Theme"
      },
      {
        "command": "leetcode-practice.switchStudyPlan",
        "title": "LeetCode: Switch Study Plan"
      },
      {
        "command": "leetcode-practice.switchProblemList",
        "title": "LeetCode: Switch Problem List"
      },
      {
        "command": "leetcode-practice.agentMakeRunnable",
        "title": "LeetCode: Ask Agent – Make Runnable"
      },
      {
        "command": "leetcode-practice.agentHint",
        "title": "LeetCode: Ask Agent – Hint"
      },
      {
        "command": "leetcode-practice.agentExplainCode",
        "title": "LeetCode: Ask Agent – Explain My Code",
        "category": "LeetCode"
      },
      {
        "command": "leetcode-practice.focusModeEnter",
        "title": "LeetCode: Focus Mode (enter)",
        "category": "LeetCode"
      },
      {
        "command": "leetcode-practice.focusModeExit",
        "title": "LeetCode: Focus Mode (exit)",
        "category": "LeetCode"
      },
      {
        "command": "leetcode-practice.setDailyGoal",
        "title": "LeetCode: Set Daily Goal",
        "category": "LeetCode"
      },
      {
        "command": "leetcode-practice.interviewModeStart",
        "title": "LeetCode: Interview Mode — Start",
        "category": "LeetCode"
      },
      {
        "command": "leetcode-practice.interviewModeStop",
        "title": "LeetCode: Interview Mode — Stop",
        "category": "LeetCode"
      },
      {
        "command": "leetcode-practice.interviewGenerateWithAi",
        "title": "LeetCode: Generate LC Interview (AI)",
        "category": "LeetCode"
      },
      {
        "command": "leetcode-practice.openLcInterviewReportFile",
        "title": "LeetCode: Open LC Interview Report…",
        "category": "LeetCode"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "leetcode-practice.agentMakeRunnable",
          "when": "leetcodePractice.hasMarker && leetcodePractice.isSolutionFile",
          "group": "navigation"
        },
        {
          "command": "leetcode-practice.agentHint",
          "when": "leetcodePractice.hasMarker && leetcodePractice.isSolutionFile && !leetcodePractice.interviewMode",
          "group": "navigation"
        },
        {
          "command": "leetcode-practice.agentExplainCode",
          "when": "leetcodePractice.hasMarker && leetcodePractice.isSolutionFile && !leetcodePractice.interviewMode",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "leetcode-practice.agentExplainCode",
          "when": "editorHasSelection && leetcodePractice.hasMarker && leetcodePractice.isSolutionFile && !leetcodePractice.interviewMode",
          "group": "navigation@9"
        }
      ],
      "view/item/context": [
        {
          "command": "leetcode-practice.markAsSolved",
          "when": "view == leetcode-practice.problemsView || view == leetcode-practice.topInterview150View || view == leetcode-practice.problemListsView || view == leetcode-practice.qotdView"
        },
        {
          "command": "leetcode-practice.markAsAttempting",
          "when": "view == leetcode-practice.problemsView || view == leetcode-practice.topInterview150View || view == leetcode-practice.problemListsView || view == leetcode-practice.qotdView"
        },
        {
          "command": "leetcode-practice.clearProblemStatus",
          "when": "view == leetcode-practice.problemsView || view == leetcode-practice.topInterview150View || view == leetcode-practice.problemListsView || view == leetcode-practice.qotdView"
        }
      ],
      "view/title": [
        {
          "command": "leetcode-practice.filterByDifficulty",
          "when": "view == leetcode-practice.problemsView",
          "group": "navigation"
        },
        {
          "command": "leetcode-practice.searchProblems",
          "when": "view == leetcode-practice.problemsView",
          "group": "navigation"
        },
        {
          "command": "leetcode-practice.filterByDifficulty",
          "when": "view == leetcode-practice.topInterview150View",
          "group": "navigation"
        },
        {
          "command": "leetcode-practice.searchProblems",
          "when": "view == leetcode-practice.topInterview150View",
          "group": "navigation"
        },
        {
          "command": "leetcode-practice.refreshQotd",
          "when": "view == leetcode-practice.qotdView",
          "group": "navigation"
        },
        {
          "command": "leetcode-practice.switchStudyPlan",
          "when": "view == leetcode-practice.topInterview150View",
          "group": "navigation"
        },
        {
          "command": "leetcode-practice.filterByDifficulty",
          "when": "view == leetcode-practice.problemListsView",
          "group": "navigation"
        },
        {
          "command": "leetcode-practice.searchProblems",
          "when": "view == leetcode-practice.problemListsView",
          "group": "navigation"
        },
        {
          "command": "leetcode-practice.switchProblemList",
          "when": "view == leetcode-practice.problemListsView",
          "group": "navigation"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "leetcode-practice.container",
          "title": "LeetCode",
          "icon": "./icons/logo-dark-16.png"
        }
      ]
    },
    "views": {
      "leetcode-practice.container": [
        {
          "id": "leetcode-practice.problemsView",
          "name": "LeetCode",
          "when": "leetcodePractice.hasMarker && leetcodePractice.showProblemset"
        },
        {
          "id": "leetcode-practice.topInterview150View",
          "name": "Study Plans",
          "when": "leetcodePractice.hasMarker && leetcodePractice.showStudyPlans"
        },
        {
          "id": "leetcode-practice.problemListsView",
          "name": "Problem Lists",
          "when": "leetcodePractice.hasMarker && leetcodePractice.showProblemLists"
        },
        {
          "id": "leetcode-practice.qotdView",
          "name": "Question of the Day",
          "when": "leetcodePractice.hasMarker && leetcodePractice.showQotd"
        }
      ]
    },
    "keybindings": [
      {
        "command": "leetcode-practice.runInTerminal",
        "key": "ctrl+shift+r",
        "mac": "cmd+shift+r"
      }
    ],
    "viewsWelcome": [
      {
        "view": "leetcode-practice.problemsView",
        "contents": "Sign in to your LeetCode account and start practicing.\n\n[Sign in to LeetCode](command:leetcode-practice.signIn)"
      },
      {
        "view": "leetcode-practice.topInterview150View",
        "contents": "Interview study plans from LeetCode.\n\n[Switch study plan](command:leetcode-practice.switchStudyPlan)"
      },
      {
        "view": "leetcode-practice.problemListsView",
        "contents": "Curated LeetCode problem lists (e.g. /problem-list/graph/). Configure `problemLists` in .leetcode.\n\n[Switch problem list](command:leetcode-practice.switchProblemList)"
      }
    ],
    "languages": [
      {
        "id": "leetcode-config",
        "aliases": [
          "LeetCode Config"
        ],
        "filenames": [
          ".leetcode"
        ],
        "icon": {
          "light": "./icons/logo-dark-16.png",
          "dark": "./icons/logo-dark-16.png"
        }
      },
      {
        "id": "leetcode-lc-interview",
        "aliases": [
          "LC Interview"
        ],
        "extensions": [
          "lcInterview",
          "lcinterview"
        ],
        "icon": {
          "light": "./icons/logo-dark-16.png",
          "dark": "./icons/logo-dark-16.png"
        }
      },
      {
        "id": "leetcode-lc-interview-report",
        "aliases": [
          "LC Interview Report"
        ],
        "extensions": [
          "lcireport"
        ],
        "icon": {
          "light": "./icons/logo-dark-16.png",
          "dark": "./icons/logo-dark-16.png"
        }
      }
    ],
    "configuration": {
      "title": "LeetCode Practice",
      "properties": {
        "leetcodePractice.defaultDirectory": {
          "type": "string",
          "default": ".",
          "description": "Default directory for new problem files (relative to workspace root or current file)."
        },
        "leetcodePractice.fileNamePattern": {
          "type": "string",
          "enum": [
            "id",
            "slug"
          ],
          "default": "id",
          "description": "New file name: 'id' → 167.ts, 'slug' → two-sum-ii-input-array-is-sorted.ts"
        },
        "leetcodePractice.language": {
          "type": "string",
          "enum": [
            "typescript",
            "javascript",
            "python"
          ],
          "default": "typescript",
          "description": "Language for generated solution files and run/submit."
        },
        "leetcodePractice.internalApiUrl": {
          "type": "string",
          "default": "",
          "description": "Optional internal API base URL. If set, fetches problem data from here instead of LeetCode."
        },
        "leetcodePractice.activeStudyPlan": {
          "type": "string",
          "default": "",
          "description": "Default study plan slug for the Study Plans sidebar when the workspace has no remembered selection. Must match an entry in studyPlans."
        },
        "leetcodePractice.activeProblemList": {
          "type": "string",
          "default": "",
          "description": "Default problem-list slug for the Problem Lists sidebar when the workspace has no remembered selection. Must match an entry in problemLists."
        },
        "leetcodePractice.activeListSource": {
          "type": "string",
          "enum": [
            "studyPlan",
            "problemList"
          ],
          "description": "Deprecated. Used only to migrate old configs (activeStudyPlan + problemList) when activeProblemList is unset."
        },
        "leetcodePractice.studyPlans": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "slug": {
                "type": "string",
                "description": "LeetCode study plan slug (e.g. top-interview-150)"
              },
              "name": {
                "type": "string",
                "description": "Display name for the study plan"
              }
            },
            "required": [
              "slug",
              "name"
            ]
          },
          "default": [
            {
              "slug": "top-interview-150",
              "name": "Top Interview 150"
            }
          ],
          "description": "Study plans to show in the Study Plans view. Add plans like top-interview-100, etc."
        },
        "leetcodePractice.problemLists": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "slug": {
                "type": "string",
                "description": "LeetCode problem-list slug (e.g. graph for /problem-list/graph/)"
              },
              "name": {
                "type": "string",
                "description": "Display name for the problem list"
              }
            },
            "required": [
              "slug",
              "name"
            ]
          },
          "default": [],
          "description": "LeetCode problem lists (favoriteQuestionList) shown in the Problem Lists sidebar."
        },
        "leetcodePractice.showProblemLists": {
          "type": "boolean",
          "default": true,
          "description": "Show the Problem Lists sidebar view."
        }
      }
    },
    "themes": [
      {
        "id": "leetcode-dark",
        "label": "LeetCode Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/leetcode-dark-color-theme.json"
      }
    ],
    "iconThemes": [
      {
        "id": "leetcode-practice-file-icons",
        "label": "LeetCode Practice",
        "path": "./icons/leetcode-file-icon-theme.json"
      }
    ],
    "customEditors": [
      {
        "id": "leetcode-practice.configEditor",
        "viewType": "leetcode-practice.configEditor",
        "displayName": "LeetCode Config",
        "selector": [
          {
            "filenamePattern": ".leetcode"
          }
        ],
        "priority": "default"
      },
      {
        "id": "leetcode-practice.lcInterviewEditor",
        "viewType": "leetcode-practice.lcInterviewEditor",
        "displayName": "LC Interview",
        "selector": [
          {
            "filenamePattern": "*.lcInterview"
          }
        ],
        "priority": "default"
      },
      {
        "id": "leetcode-practice.lcInterviewReportEditor",
        "viewType": "leetcode-practice.lcInterviewReportEditor",
        "displayName": "LC Interview Report",
        "selector": [
          {
            "filenamePattern": "*.lcireport"
          }
        ],
        "priority": "default"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./ && npm run copy-assets",
    "copy-assets": "copyfiles -u 1 \"src/templates/*.ejs\" out",
    "watch": "tsc -w -p ./",
    "test": "node --test --import tsx test/integration.test.ts",
    "package": "npm run compile && npx vsce package",
    "install-extension": "npm run package && code --install-extension leetcode-practice-0.1.0.vsix --force"
  },
  "devDependencies": {
    "@types/ejs": "^3.1.3",
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.2.1",
    "copyfiles": "^2.4.1",
    "tsx": "^4.19.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "ejs": "^3.1.9",
    "shiki": "^4.0.2"
  }
}
