      },
      {
        "command": "leetcode-practice.markAsAttempting",
        "title": "Mark as Attempting"
      },
      {
        "command": "leetcode-practice.clearProblemStatus",
        "title": "Clear Status"
      },
      {
        "command": "leetcode-practice.filterByDifficulty",
        "title": "LeetCode: Filter by Difficulty"
      },
      {
        "command": "leetcode-practice.searchProblems",
        "title": "LeetCode: Search Problems"
      },
      {
        "command": "leetcode-practice.openRandomProblem",
        "title": "LeetCode: Open Random Problem"
      },
      {
        "command": "leetcode-practice.practicePattern",
