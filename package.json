    "menus": {
      "editor/title": [
        {
          "command": "leetcode-practice.agentMakeRunnable",
          "when": "leetcodePractice.hasMarker && leetcodePractice.isSolutionFile",
          "group": "navigation"
        },
        {
          "command": "leetcode-practice.agentHint",
          "when": "leetcodePractice.hasMarker && leetcodePractice.isSolutionFile && !leetcodePractice.interviewMode",
          "group": "navigation"
        },
        {
          "command": "leetcode-practice.agentAnalyze",
          "when": "leetcodePractice.hasMarker && leetcodePractice.isSolutionFile && !leetcodePractice.interviewMode",
          "group": "navigation"
        },
        {
          "command": "leetcode-practice.openHintAnalysis",
          "when": "leetcodePractice.hasMarker && leetcodePractice.isSolutionFile && !leetcodePractice.interviewMode",
          "group": "navigation"
        },
        {
          "command": "leetcode-practice.agentExplainCode",
          "when": "leetcodePractice.hasMarker && leetcodePractice.isSolutionFile && !leetcodePractice.interviewMode",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "leetcode-practice.agentExplainCode",
          "when": "editorHasSelection && leetcodePractice.hasMarker && leetcodePractice.isSolutionFile && !leetcodePractice.interviewMode",
          "group": "navigation@9"
        }
      ],
      "view/item/context": [
        {
          "command": "leetcode-practice.markAsSolved",
          "when": "view == leetcode-practice.problemsView || view == leetcode-practice.topInterview150View || view == leetcode-practice.problemListsView || view == leetcode-practice.qotdView || (view == leetcode-practice.contestsView && viewItem == lcex.contestProblem) || (view == leetcode-practice.companiesView && viewItem == lcex.companyProblem)"
        },
        {
          "command": "leetcode-practice.markAsAttempting",
          "when": "view == leetcode-practice.problemsView || view == leetcode-practice.topInterview150View || view == leetcode-practice.problemListsView || view == leetcode-practice.qotdView || (view == leetcode-practice.contestsView && viewItem == lcex.contestProblem) || (view == leetcode-practice.companiesView && viewItem == lcex.companyProblem)"
        },
        {
          "command": "leetcode-practice.clearProblemStatus",
          "when": "view == leetcode-practice.problemsView || view == leetcode-practice.topInterview150View || view == leetcode-practice.problemListsView || view == leetcode-practice.qotdView || (view == leetcode-practice.contestsView && viewItem == lcex.contestProblem) || (view == leetcode-practice.companiesView && viewItem == lcex.companyProblem)"
        },
        {
          "command": "leetcode-practice.openContestOnWeb",
          "when": "view == leetcode-practice.contestsView && (viewItem == lcex.upcomingContest || viewItem == lcex.pastContest)",
          "group": "inline"
        }
      ],
      "view/title": [
        {
          "command": "leetcode-practice.filterByDifficulty",
          "when": "view == leetcode-practice.problemsView",
          "group": "navigation"
        },
        {
          "command": "leetcode-practice.searchProblems",
          "when": "view == leetcode-practice.problemsView",
          "group": "navigation"
        },
        {
          "command": "leetcode-practice.filterByDifficulty",
          "when": "view == leetcode-practice.topInterview150View",
          "group": "navigation"
        },
        {
          "command": "leetcode-practice.searchProblems",
          "when": "view == leetcode-practice.topInterview150View",
          "group": "navigation"
        },
        {
          "command": "leetcode-practice.refreshQotd",
          "when": "view == leetcode-practice.qotdView",
          "group": "navigation"
        },
        {
          "command": "leetcode-practice.switchStudyPlan",
          "when": "view == leetcode-practice.topInterview150View",
          "group": "navigation"
        },
        {
          "command": "leetcode-practice.filterByDifficulty",
          "when": "view == leetcode-practice.problemListsView",
          "group": "navigation"
        },
        {
          "command": "leetcode-practice.searchProblems",
          "when": "view == leetcode-practice.problemListsView",
          "group": "navigation"
        },
        {
          "command": "leetcode-practice.switchProblemList",
          "when": "view == leetcode-practice.problemListsView",
          "group": "navigation"
        },
        {
          "command": "leetcode-practice.refreshContests",
          "when": "view == leetcode-practice.contestsView",
          "group": "navigation"
        },
        {
          "command": "leetcode-practice.searchCompanies",
          "when": "view == leetcode-practice.companiesView",
          "group": "navigation@1"
        },
        {
          "command": "leetcode-practice.filterCompaniesByDifficulty",
          "when": "view == leetcode-practice.companiesView",
          "group": "navigation@2"
        },
        {
          "command": "leetcode-practice.refreshCompanies",
          "when": "view == leetcode-practice.companiesView",
          "group": "navigation@3"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "leetcode-practice.container",
          "title": "LeetCode",
          "icon": "./icons/icon-mono.svg"
        }
      ]
    },
    "views": {
      "leetcode-practice.container": [
        {
          "id": "leetcode-practice.problemsView",
          "name": "LeetCode",
          "when": "leetcodePractice.hasMarker && leetcodePractice.showProblemset"
        },
        {
          "id": "leetcode-practice.topInterview150View",
          "name": "Study Plans",
          "when": "leetcodePractice.hasMarker && leetcodePractice.showStudyPlans"
        },
        {
          "id": "leetcode-practice.problemListsView",
          "name": "Problem Lists",
          "when": "leetcodePractice.hasMarker && leetcodePractice.showProblemLists"
        },
        {
          "id": "leetcode-practice.qotdView",
          "name": "Question of the Day",
          "when": "leetcodePractice.hasMarker && leetcodePractice.showQotd"
        },
        {
          "id": "leetcode-practice.contestsView",
          "name": "Practice Past Contests",
          "when": "leetcodePractice.hasMarker && leetcodePractice.showContests"
        },
        {
          "id": "leetcode-practice.companiesView",
          "name": "Companies",
          "when": "leetcodePractice.hasMarker && leetcodePractice.showCompanies"
        },
        {
          "id": "leetcode-practice.patternMasteryView",
          "name": "Pattern Mastery",
          "when": "leetcodePractice.hasMarker"
        }
      ]
    },
    "keybindings": [
      {
        "command": "leetcode-practice.runInTerminal",
        "key": "ctrl+shift+r",
        "mac": "cmd+shift+r",
        "when": "leetcodePractice.hasMarker && leetcodePractice.isSolutionFile && editorTextFocus"
      },
      {
        "command": "leetcode-practice.clearInlineDecorations",
        "key": "ctrl+k ctrl+l",
        "mac": "cmd+k cmd+l",
        "when": "leetcodePractice.hasMarker && editorTextFocus"
      }
    ],
    "viewsWelcome": [
      {
        "view": "leetcode-practice.problemsView",
        "contents": "Sign in to your LeetCode account and start practicing.\n\n[Sign in to LeetCode](command:leetcode-practice.signIn)"
      },
      {
        "view": "leetcode-practice.topInterview150View",
        "contents": "Interview study plans from LeetCode.\n\n[Switch study plan](command:leetcode-practice.switchStudyPlan)"
      },
      {
        "view": "leetcode-practice.problemListsView",
        "contents": "Curated LeetCode problem lists (e.g. /problem-list/graph/). Configure `problemLists` in .leetcode.\n\n[Switch problem list](command:leetcode-practice.switchProblemList)"
      }
    ],
    "languages": [
      {
        "id": "leetcode-config",
        "aliases": [
          "LeetCode Config"
        ],
        "filenames": [
          ".leetcode"
        ],
        "icon": {
          "light": "./icons/logo-dark-16.png",
          "dark": "./icons/logo-dark-16.png"
        }
      },
      {
        "id": "leetcode-lc-interview",
        "aliases": [
          "LC Interview"
        ],
        "extensions": [
          "lcInterview",
          "lcinterview"
        ],
        "icon": {
          "light": "./icons/logo-dark-16.png",
          "dark": "./icons/logo-dark-16.png"
        }
      },
      {
        "id": "leetcode-lc-interview-report",
        "aliases": [
          "LC Interview Report"
        ],
        "extensions": [
          "lcireport"
        ],
        "icon": {
          "light": "./icons/logo-dark-16.png",
          "dark": "./icons/logo-dark-16.png"
        }
      },
      {
        "id": "leetcode-hint",
        "aliases": [
          "LeetCode Hint"
        ],
        "extensions": [
          "hint"
        ],
        "icon": {
          "light": "./icons/hint.svg",
          "dark": "./icons/hint.svg"
        }
      }
    ],
    "configuration": {
      "title": "LeetCode Practice",
      "properties": {
        "leetcodePractice.defaultDirectory": {
          "type": "string",
          "default": ".",
          "description": "Default directory for new problem files (relative to workspace root or current file)."
        },
        "leetcodePractice.fileNamePattern": {
          "type": "string",
          "enum": [
            "id",
            "slug"
          ],
          "default": "id",
          "description": "New file name: 'id' → 167.ts, 'slug' → two-sum-ii-input-array-is-sorted.ts"
        },
        "leetcodePractice.language": {
          "type": "string",
          "enum": [
            "typescript",
            "javascript",
            "python",
            "cpp",
            "java"
          ],
          "default": "typescript",
          "description": "Language for generated solution files and run/submit."
        },
        "leetcodePractice.problemViewMode": {
          "type": "string",
          "enum": [
            "ui",
            "text"
          ],
          "default": "ui",
          "description": "When opening a problem from sidebar lists: 'ui' (webview with run/submit) or 'text' (plain statement in an editor tab). Overridden by problemViewMode in a workspace .leetcode file when set."
        },
        "leetcodePractice.suppressAiTabOnSolve": {
          "type": "boolean",
          "default": true,
          "description": "In workspaces with a root .leetcode file, when you open/create a solution from the problem page, write workspace settings to reduce Tab/inline AI completions for that solution language (editor.inlineSuggest.enabled false and editor.tabCompletion off in [typescript]/[javascript]/[python]/[cpp]/[java])."
        },
        "leetcodePractice.suppressAiTabWorkspaceWide": {
          "type": "boolean",
          "default": false,
          "description": "If suppressAiTabOnSolve is enabled, set editor.inlineSuggest.enabled to false for the whole workspace instead of per-language scopes (stronger; affects all file types in this workspace folder)."
        },
        "leetcodePractice.internalApiUrl": {
          "type": "string",
          "default": "",
          "description": "Optional internal API base URL. If set, fetches problem data from here instead of LeetCode."
        },
        "leetcodePractice.activeStudyPlan": {
          "type": "string",
          "default": "",
          "description": "Default study plan slug for the Study Plans sidebar when the workspace has no remembered selection. Must match an entry in studyPlans."
        },
        "leetcodePractice.activeProblemList": {
          "type": "string",
          "default": "",
          "description": "Default problem-list slug for the Problem Lists sidebar when the workspace has no remembered selection. Must match an entry in problemLists."
        },
        "leetcodePractice.activeListSource": {
          "type": "string",
          "enum": [
            "studyPlan",
            "problemList"
          ],
          "description": "Deprecated. Used only to migrate old configs (activeStudyPlan + problemList) when activeProblemList is unset."
        },
        "leetcodePractice.studyPlans": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "slug": {
                "type": "string",
                "description": "LeetCode study plan slug (e.g. top-interview-150)"
              },
              "name": {
                "type": "string",
                "description": "Display name for the study plan"
              }
            },
            "required": [
              "slug",
              "name"
            ]
          },
          "default": [
            {
              "slug": "top-interview-150",
              "name": "Top Interview 150"
            }
          ],
          "description": "Study plans to show in the Study Plans view. Add plans like top-interview-100, etc."
        },
        "leetcodePractice.problemLists": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "slug": {
                "type": "string",
                "description": "LeetCode problem-list slug (e.g. graph for /problem-list/graph/)"
              },
              "name": {
                "type": "string",
                "description": "Display name for the problem list"
              }
            },
            "required": [
              "slug",
              "name"
            ]
          },
          "default": [],
          "description": "LeetCode problem lists (favoriteQuestionList) shown in the Problem Lists sidebar."
        },
        "leetcodePractice.showProblemLists": {
          "type": "boolean",
          "default": true,
          "description": "Show the Problem Lists sidebar view."
        },
        "leetcodePractice.leetcodeUsername": {
          "type": "string",
          "default": "",
          "description": "LeetCode handle used as the per-account document id for cloud stats. Cloud path: users/<your-firebase-uid>/stats/<username>. Sign in with 'LeetCode: Sign in to Cloud Sync' first."
        },
        "leetcodePractice.analytics.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Send anonymous usage analytics (which features are used, bucketed durations, language, coarse timestamps). No problem slugs, notes, file paths, or identifying info are ever sent. Only an opaque per-install UUID identifies the sender. Works without sign-in (a per-install anonymous Firebase identity is minted on first send). Disabled automatically if VS Code telemetry is off."
        },
        "leetcodePractice.inlineDecorations.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Master switch for all lcex inline ghost-text decorations (lint, complexity budget, edge-case probes, example results). Turn off for clean screenshots or distraction-free mode."
        },
        "leetcodePractice.lint.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Run the interview anti-pattern linter on save (mutate-input, built-in sort, magic numbers, debug prints). Inline + Problems panel."
        },
        "leetcodePractice.complexityBudget.enabled": {
          "type": "boolean",
          "default": true,
          "description": "On save, derive a complexity budget from the problem's size constraints and compare against your solution's estimated loop nesting. Shows 🟢/🟡/🔴 on the signature and per-loop badges."
        },
        "leetcodePractice.adversarialTests.enabled": {
          "type": "boolean",
          "default": false,
          "description": "On save, surface edge-case probes derived from parsed constraints (empty, max-size, boundary, negatives) as an inline hint on the function signature. Off by default — enable or run `LeetCode: Surface Adversarial Edge Cases` on demand."
        },
        "leetcodePractice.runExamplesOnSave.enabled": {
          "type": "boolean",
          "default": true,
          "description": "On save, run the solution's example lines automatically and show results inline. Spawns a language process per save — disable if iteration feels sluggish."
        },
        "leetcodePractice.runExamples.sandbox": {
          "type": "string",
          "enum": ["auto", "sandbox", "off"],
          "default": "auto",
          "markdownDescription": "Sandbox solution execution. `auto` (default) uses macOS `sandbox-exec` on Darwin, normal execution elsewhere. `sandbox` forces sandbox (fails on platforms without a backend). `off` runs the solution unsandboxed (legacy behaviour). The sandbox blocks network access and writes outside the toolchain's scratch directories."
        },
        "leetcodePractice.bugReview.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Spaced-repetition bug review: when an example fails, snapshot the failing test (input, expected, actual, full source) to ~/.lcex/bug-reviews.json and resurface it 3/7/30/90 days later as a re-attempt drill. Status bar shows count due. Off by default — enable to start building the queue."
        },
        "leetcodePractice.fuzzer.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Differential fuzzer: define `bruteForce` and `fuzzInputs(seed)` (or `brute_force`/`fuzz_inputs` in Python) alongside your solution; the fuzzer runs both on random inputs and reports the first divergence as a counterexample. Off by default."
        },
        "leetcodePractice.empiricalFit.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Empirical complexity fitter: define `benchmark(n)` (or `def benchmark(n)`) that runs your solution at size n; the fitter times it at growing N and fits a curve (const/log/sqrt/n/n log n/n²/n³/2ⁿ). Surfaces a verdict if the empirical class exceeds the static estimate. Off by default."
        },
        "leetcodePractice.recursionTree.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Recursion call-tree visualizer: instruments the recursive function in the open file (TS/JS via wrapper, Python via sys.setprofile), runs it, and renders the live call tree with memoization-hit edges in a webview. Off by default."
        },
        "leetcodePractice.iterativeVisualizer.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Iterative traversal visualizer: wraps push/pop on a user-tracked stack/queue (`lcexTrace.track(container, \"stack\"|\"queue\")` in TS/JS, `lcex_trace.track(...)` in Python) and renders the resulting traversal tree with revisit edges. Off by default."
        },
        "leetcodePractice.showContests": {
          "type": "boolean",
          "default": true,
          "description": "Show the Contests sidebar view (past weekly/biweekly + upcoming-contest metadata). Past contest problems open in the editor; upcoming contests show a countdown and an 'Open on leetcode.com' action only — live-contest questions are intentionally not surfaced."
        },
        "leetcodePractice.showCompanies": {
          "type": "boolean",
          "default": true,
          "description": "Show the Companies sidebar view — browse LeetCode problems grouped by company (frequency, acceptance, difficulty, topics) sourced from liquidslr/interview-company-wise-problems."
        },
        "leetcodePractice.timerMode": {
          "type": "string",
          "enum": [
            "auto",
            "reverse"
          ],
          "default": "auto",
          "description": "Per-problem timer direction. 'auto' counts up from 00:00. 'reverse' counts down from a difficulty-based budget (Easy 15min, Medium 30min, Hard 45min) toward 00:00, then continues into negative as overtime."
        }
      }
    },
    "themes": [
      {
        "id": "leetcode-dark",
        "label": "LeetCode Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/leetcode-dark-color-theme.json"
      }
    ],
    "iconThemes": [
      {
        "id": "leetcode-practice-file-icons",
        "label": "LeetCode Practice",
        "path": "./icons/leetcode-file-icon-theme.json"
      }
    ],
    "customEditors": [
      {
        "id": "leetcode-practice.configEditor",
        "viewType": "leetcode-practice.configEditor",
        "displayName": "LeetCode Config",
        "selector": [
          {
            "filenamePattern": ".leetcode"
          }
        ],
        "priority": "default"
      },
      {
        "id": "leetcode-practice.lcInterviewEditor",
        "viewType": "leetcode-practice.lcInterviewEditor",
        "displayName": "LC Interview",
        "selector": [
          {
            "filenamePattern": "*.lcInterview"
          }
        ],
        "priority": "default"
      },
      {
        "id": "leetcode-practice.lcInterviewReportEditor",
        "viewType": "leetcode-practice.lcInterviewReportEditor",
        "displayName": "LC Interview Report",
        "selector": [
          {
            "filenamePattern": "*.lcireport"
          }
        ],
        "priority": "default"
      },
      {
        "id": "leetcode-practice.hintEditor",
        "viewType": "leetcode-practice.hintEditor",
        "displayName": "LeetCode solution notes (.hint)",
        "selector": [
          {
            "filenamePattern": "*.hint"
          }
        ],
        "priority": "default"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run bundle",
    "typecheck": "tsc -p ./ --noEmit",
    "bundle": "node esbuild.config.mjs",
    "compile": "npm run typecheck && npm run bundle",
    "build:companies-data": "node scripts/build-companies-data.mjs",
    "watch": "node esbuild.config.mjs --watch",
    "test": "node --test --import tsx test/integration.test.ts",
    "package": "npm run compile && npx vsce package",
    "install-extension": "npm run package && node -e \"const v=require('./package.json').version;require('child_process').execSync('code --install-extension leetcode-practice-'+v+'.vsix --force',{stdio:'inherit'})\""
  },
  "devDependencies": {
    "@types/ejs": "^3.1.3",
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.2.1",
    "copyfiles": "^2.4.1",
    "esbuild": "^0.28.0",
    "tsx": "^4.19.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "ejs": "^3.1.9",
    "shiki": "^4.0.2"
  }
}
