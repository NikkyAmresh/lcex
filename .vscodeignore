# Source — bundled into out/extension.js by esbuild
src/**
tsconfig.json
esbuild.config.mjs
.gitignore
.vscodeignore

.openvsx
.cf

# Dev artefacts
.vscode/**
.github/**
.claude/**
.cursor/**
test/**
test-output/**
node_modules/**
scripts/**

# Repo docs (README.md is included by vsce automatically; ignore other markdown)
CLAUDE.md

# Cloud / backend artefacts not needed in extension
.firebase/**
.firebaserc
firebase.json
firestore.rules
auth-page/**

# Chrome extension lives here as a sibling, not part of the VS Code extension
chrome-extension/**
chrome-extension.crx
chrome-extension.pem
*.pem

# Screenshots — README references them via raw.githubusercontent.com, so they
# don't need to ship inside the .vsix. Saves ~3.7 MB.
screenshots/**

# Personal solution files / interview plans / hint notes that should never ship
*.ts
*.tsx
*.js
*.mjs
*.cjs
*.py
*.cpp
*.hint
*.lcInterview
*.lcireport
*.leetcode
Interview*/**
Meta*/**
backfill-*.json
*.vsix
*.vsix.zip
*.png.zip
leetcode-practice-*.png

# But keep what we DO want shipped (whitelist overrides above)
!out/**/*.js
!out/**/*.ejs
!out/data/**/*.json
!icons/**
!themes/**
!resources/**
!package.json
!LICENSE
!README.md
!CHANGELOG.md
