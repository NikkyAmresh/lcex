<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>LeetCode Practice Stats</title>
    <style>
      :root {
        --bg: #1e1e1e;
        --text: #e5e5e5;
        --text-muted: #9d9d9d;
        --easy: #26a641;
        --medium: #d39b00;
        --hard: #dc3545;
        --border: #3c3c3c;
      }
      body {
        margin: 0;
        padding: 24px;
        font-family: var(--vscode-font-family, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif);
        font-size: 14px;
        background: var(--bg);
        color: var(--text);
      }
      h1 { font-size: 22px; margin: 0 0 20px; }
      .stat { margin-bottom: 16px; }
      .stat-label { color: var(--text-muted); font-size: 12px; }
      .stat-value { font-size: 28px; font-weight: 600; }
      .stat.easy .stat-value { color: var(--easy); }
      .stat.medium .stat-value { color: var(--medium); }
      .stat.hard .stat-value { color: var(--hard); }
      .row { display: flex; gap: 24px; flex-wrap: wrap; }
      .row .stat { min-width: 80px; }
      .profile-section { margin-bottom: 28px; }
      .profile-card { display: flex; align-items: center; gap: 12px; margin-bottom: 16px; }
      .profile-avatar { width: 48px; height: 48px; border-radius: 50%; object-fit: cover; }
      .profile-info { display: flex; flex-direction: column; gap: 2px; }
      .profile-username { font-weight: 600; font-size: 16px; }
      .profile-realname { color: var(--text-muted); font-size: 13px; }
      .subsection { font-size: 16px; margin: 16px 0 12px; color: var(--text-muted); font-weight: 500; }
      .local-section { border-top: 1px solid var(--border); padding-top: 20px; }
      .time-by-day { margin-top: 24px; }
      .time-day-row { display: flex; align-items: center; gap: 12px; margin-bottom: 10px; }
      .time-day-date { min-width: 100px; color: var(--text-muted); font-size: 13px; }
      .time-day-bar-wrap { flex: 1; min-width: 0; height: 20px; background: var(--border); border-radius: 4px; overflow: hidden; }
      .time-day-bar { height: 100%; background: var(--easy); border-radius: 4px; transition: width 0.2s; }
      .time-day-mins { min-width: 100px; text-align: right; font-size: 13px; color: var(--text-muted); white-space: nowrap; }
      .time-day-solved { min-width: 64px; text-align: right; font-size: 13px; color: var(--easy); }
      .time-day-breakdown { margin-left: 180px; margin-bottom: 12px; padding: 8px 12px; background: rgba(255,255,255,0.04); border-radius: 6px; font-size: 12px; }
      .time-day-breakdown summary { cursor: pointer; color: var(--text-muted); }
      .time-day-breakdown ul { margin: 6px 0 0; padding-left: 16px; }
      .time-day-breakdown li { margin: 2px 0; }
      .time-note { color: var(--text-muted); font-size: 11px; }
      .insights { margin-top: 8px; }
      .insight-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
        gap: 12px;
        margin-bottom: 20px;
      }
      .insight-card {
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 12px 14px;
      }
      .insight-label { color: var(--text-muted); font-size: 11px; text-transform: uppercase; letter-spacing: 0.04em; margin-bottom: 6px; }
      .insight-value { font-size: 20px; font-weight: 600; color: var(--text); }
      .insight-hint { color: var(--text-muted); font-size: 11px; margin: 8px 0 0; line-height: 1.4; }
      .chart-panel { margin-top: 20px; overflow-x: auto; border: 1px solid var(--border); border-radius: 8px; padding: 12px 12px 8px; background: rgba(0,0,0,0.15); }
      .chart-head { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 8px; flex-wrap: wrap; gap: 8px; }
      .chart-title { font-size: 13px; font-weight: 600; color: var(--text); }
      .chart-scale { font-size: 11px; color: var(--text-muted); }
      .chart-svg { display: block; width: 100%; height: auto; min-height: 160px; max-height: 220px; }
      .chart-bar { fill: var(--easy); opacity: 0.85; }
      .chart-bar-solved { fill: var(--medium); opacity: 0.85; }
      .chart-line-time { fill: none; stroke: #59c1ff; stroke-width: 2; stroke-linejoin: round; stroke-linecap: round; }
      .chart-line-solved { fill: none; stroke: #d39b00; stroke-width: 2; stroke-linejoin: round; stroke-linecap: round; }
      .chart-axis-text { fill: var(--text-muted); font-size: 10px; }
      .chart-0 { stroke: var(--border); stroke-width: 1; }
      .stats-cache-hint {
        margin: 20px 0 0;
        padding-top: 16px;
        border-top: 1px solid var(--border);
        color: var(--text-muted);
        font-size: 11px;
        line-height: 1.45;
      }
      .goal-bar-wrap {
        height: 22px;
        background: var(--border);
        border-radius: 6px;
        overflow: hidden;
        margin-top: 8px;
        max-width: 480px;
      }
      .goal-bar-fill {
        height: 100%;
        background: var(--medium);
        border-radius: 6px;
        min-width: 0;
      }
      .interview-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
        margin-top: 12px;
      }
      .interview-table th,
      .interview-table td {
        text-align: left;
        padding: 8px 10px;
        border-bottom: 1px solid var(--border);
      }
      .interview-table th {
        color: var(--text-muted);
        font-weight: 500;
        font-size: 12px;
      }
    </style>
  </head>
  <body>
    <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 20px;">
      <img src="<%= logoUri %>" alt="LeetCode" style="height: 28px; width: auto;" />
      <h1 style="margin: 0; font-size: 22px;">LeetCode Practice Stats</h1>
    </div>
    <% if (typeof leetcodeProfile !== 'undefined' && leetcodeProfile) { %>
    <section class="profile-section">
      <h1>Profile</h1>
      <div class="profile-card">
        <% if (leetcodeProfile.userAvatar) { %>
        <img class="profile-avatar" src="<%= leetcodeProfile.userAvatar %>" alt="" />
        <% } %>
        <div class="profile-info">
          <span class="profile-username"><%= leetcodeProfile.username %></span>
          <% if (leetcodeProfile.realName) { %>
          <span class="profile-realname"><%= leetcodeProfile.realName %></span>
          <% } %>
        </div>
      </div>
      <h2 class="subsection">Solved on LeetCode</h2>
      <div class="stat">
        <div class="stat-label">Total solved</div>
        <div class="stat-value"><%= leetcodeProfile.totalSolved %></div>
      </div>
      <div class="row">
        <div class="stat easy">
          <div class="stat-label">Easy</div>
          <div class="stat-value"><%= leetcodeProfile.easySolved %></div>
        </div>
        <div class="stat medium">
          <div class="stat-label">Medium</div>
          <div class="stat-value"><%= leetcodeProfile.mediumSolved %></div>
        </div>
        <div class="stat hard">
          <div class="stat-label">Hard</div>
          <div class="stat-value"><%= leetcodeProfile.hardSolved %></div>
        </div>
      </div>
      <h2 class="subsection">Practice (this extension)</h2>
      <div class="stat">
        <div class="stat-label">Local solved / streak</div>
        <div class="stat-value" style="font-size: 20px;"><%= totalSolved %> solved · <%= streak %> day streak</div>
      </div>
      <div class="stat" style="margin-top: 12px;">
        <div class="stat-label">Level &amp; XP (local)</div>
        <div class="stat-value" style="font-size: 22px;">Level <%= typeof xpLevel !== 'undefined' ? xpLevel : 1 %></div>
        <div style="color: var(--text-muted); font-size: 13px; margin-top: 6px;">
          <%= typeof totalXp !== 'undefined' ? totalXp : 0 %> total XP
          <% if (typeof xpNeededForNext !== 'undefined' && xpNeededForNext) { %>
          · <%= typeof xpInLevel !== 'undefined' ? xpInLevel : 0 %> / <%= xpNeededForNext %> toward next level
          <% } %>
        </div>
      </div>
      <% if (typeof dailyGoalSection !== 'undefined' && dailyGoalSection) { %>
      <div class="stat" style="margin-top: 16px;">
        <div class="stat-label">Daily goal — <%= dailyGoalSection.label %></div>
        <div style="font-size: 18px; font-weight: 600; margin-top: 4px;"><%= dailyGoalSection.current %> / <%= dailyGoalSection.target %></div>
        <div class="goal-bar-wrap">
          <div class="goal-bar-fill" style="width: <%= dailyGoalSection.percent %>%;"></div>
        </div>
        <div style="color: var(--text-muted); font-size: 12px; margin-top: 6px;"><%= dailyGoalSection.percent %>% complete</div>
      </div>
      <% } %>
    </section>
    <% } else { %>
    <section class="local-section">
      <h1>Practice Stats (local)</h1>
      <div class="stat">
        <div class="stat-label">Total solved</div>
        <div class="stat-value"><%= totalSolved %></div>
      </div>
      <div class="row">
        <div class="stat easy">
          <div class="stat-label">Easy</div>
          <div class="stat-value"><%= easySolved %></div>
        </div>
        <div class="stat medium">
          <div class="stat-label">Medium</div>
          <div class="stat-value"><%= mediumSolved %></div>
        </div>
        <div class="stat hard">
          <div class="stat-label">Hard</div>
          <div class="stat-value"><%= hardSolved %></div>
        </div>
      </div>
      <div class="stat">
        <div class="stat-label">Attempting</div>
        <div class="stat-value"><%= attempting %></div>
      </div>
      <div class="stat">
        <div class="stat-label">Current streak (days)</div>
        <div class="stat-value"><%= streak %></div>
      </div>
      <div class="stat" style="margin-top: 20px;">
        <div class="stat-label">Level &amp; XP (local)</div>
        <div class="stat-value" style="font-size: 22px;">Level <%= typeof xpLevel !== 'undefined' ? xpLevel : 1 %></div>
        <div style="color: var(--text-muted); font-size: 13px; margin-top: 6px;">
          <%= typeof totalXp !== 'undefined' ? totalXp : 0 %> total XP
          <% if (typeof xpNeededForNext !== 'undefined' && xpNeededForNext) { %>
          · <%= typeof xpInLevel !== 'undefined' ? xpInLevel : 0 %> / <%= xpNeededForNext %> toward next level
          <% } %>
        </div>
      </div>
      <% if (typeof dailyGoalSection !== 'undefined' && dailyGoalSection) { %>
      <div class="stat" style="margin-top: 16px;">
        <div class="stat-label">Daily goal — <%= dailyGoalSection.label %></div>
        <div style="font-size: 18px; font-weight: 600; margin-top: 4px;"><%= dailyGoalSection.current %> / <%= dailyGoalSection.target %></div>
        <div class="goal-bar-wrap">
          <div class="goal-bar-fill" style="width: <%= dailyGoalSection.percent %>%;"></div>
        </div>
        <div style="color: var(--text-muted); font-size: 12px; margin-top: 6px;"><%= dailyGoalSection.percent %>% complete</div>
      </div>
      <% } %>
    </section>
    <% } %>
    <% if (typeof timeAnalysis !== 'undefined' && timeAnalysis && typeof timeChartBars !== 'undefined' && timeChartBars.length > 0) { %>
    <section class="insights local-section">
      <h2 class="subsection">Time insights</h2>
      <div class="insight-grid">
        <div class="insight-card">
          <div class="insight-label">Total (timer ticks)</div>
          <div class="insight-value"><%= timeAnalysis.totalTimerLabel %></div>
          <p class="insight-hint">Sum of seconds recorded per day by the practice timer. Most accurate total.</p>
        </div>
        <div class="insight-card">
          <div class="insight-label">Total (sum of daily rows)</div>
          <div class="insight-value"><%= timeAnalysis.totalDailyRowsLabel %></div>
          <p class="insight-hint">Matches the list below; can exceed timer total when “total tracked” minutes appear on multiple days.</p>
        </div>
        <div class="insight-card">
          <div class="insight-label">Most active day (time)</div>
          <div class="insight-value" style="font-size: 15px;"><%= timeAnalysis.mostActiveLabel %></div>
          <p class="insight-hint">Day with the highest minutes in the daily breakdown.</p>
        </div>
        <div class="insight-card">
          <div class="insight-label">Avg on days with time</div>
          <div class="insight-value"><%= timeAnalysis.avgPracticeDaysLabel %></div>
          <p class="insight-hint"><%= timeAnalysis.daysWithPracticeTime %> day<%= timeAnalysis.daysWithPracticeTime === 1 ? '' : 's' %> with &gt; 0 min.</p>
        </div>
        <div class="insight-card">
          <div class="insight-label">Busiest day (solved)</div>
          <div class="insight-value" style="font-size: 15px;">
            <% if (timeAnalysis.peakSolvedDate) { %><%= timeAnalysis.peakSolvedDate %> · <%= timeAnalysis.peakSolvedCount %> solved<% } else { %>—<% } %>
          </div>
          <p class="insight-hint">Most problems marked solved on one calendar day.</p>
        </div>
      </div>
      <div class="chart-panel">
        <div class="chart-head">
          <span class="chart-title">Minutes per day</span>
          <span class="chart-scale">Scale max <%= timeAnalysis.chartTimeMaxLabel %></span>
        </div>
        <svg class="chart-svg" viewBox="<%= chartViewBox %>" preserveAspectRatio="xMidYMid meet" role="img" aria-label="Bar and line chart of practice minutes per day">
          <title>Minutes per day</title>
          <line class="chart-0" x1="<%= chartAxis.x1 %>" y1="<%= chartAxis.yBottom %>" x2="<%= chartAxis.x2 %>" y2="<%= chartAxis.yBottom %>" />
          <% timeChartBars.forEach(function(b) { %>
          <rect class="chart-bar" x="<%= b.x %>" y="<%= b.y %>" width="<%= b.w %>" height="<%= Math.max(b.h, 0) %>" rx="2">
            <title><%= b.date %>: <%= formatDuration(b.value) %></title>
          </rect>
          <% }); %>
          <% if (typeof timeLinePoints !== 'undefined' && timeLinePoints) { %>
          <polyline class="chart-line-time" points="<%= timeLinePoints %>" />
          <% } %>
          <% xLabelIndices.forEach(function(i) { 
               var b = timeChartBars[i];
               if (!b || !statsChrono[i]) return;
               var cx = b.x + b.w / 2;
          %>
          <text class="chart-axis-text" x="<%= cx %>" y="<%= chartAxis.labelY %>" text-anchor="middle"><%= statsChrono[i].date.slice(5) %></text>
          <% }); %>
        </svg>
      </div>
      <div class="chart-panel">
        <div class="chart-head">
          <span class="chart-title">Solved count per day</span>
          <span class="chart-scale">Scale max <%= timeAnalysis.chartSolvedMax %> solved</span>
        </div>
        <svg class="chart-svg" viewBox="<%= chartViewBox %>" preserveAspectRatio="xMidYMid meet" role="img" aria-label="Bar and line chart of problems solved per day">
          <title>Solved per day</title>
          <line class="chart-0" x1="<%= chartAxis.x1 %>" y1="<%= chartAxis.yBottom %>" x2="<%= chartAxis.x2 %>" y2="<%= chartAxis.yBottom %>" />
          <% solvedChartBars.forEach(function(b) { %>
          <rect class="chart-bar-solved" x="<%= b.x %>" y="<%= b.y %>" width="<%= b.w %>" height="<%= Math.max(b.h, 0) %>" rx="2">
            <title><%= b.date %>: <%= b.value %> solved</title>
          </rect>
          <% }); %>
          <% if (typeof solvedLinePoints !== 'undefined' && solvedLinePoints) { %>
          <polyline class="chart-line-solved" points="<%= solvedLinePoints %>" />
          <% } %>
          <% xLabelIndices.forEach(function(i) { 
               var b = solvedChartBars[i];
               if (!b || !statsChrono[i]) return;
               var cx = b.x + b.w / 2;
          %>
          <text class="chart-axis-text" x="<%= cx %>" y="<%= chartAxis.labelY %>" text-anchor="middle"><%= statsChrono[i].date.slice(5) %></text>
          <% }); %>
        </svg>
      </div>
    </section>
    <% } %>
    <% if (typeof interviewHistory !== 'undefined' && interviewHistory && interviewHistory.length > 0) { %>
    <section class="local-section">
      <h2 class="subsection">Interview mode sessions</h2>
      <p style="color: var(--text-muted); font-size: 13px; margin: 0 0 8px;">Recent timed sessions (bonus XP from solved problems; 0 if none solved).</p>
      <table class="interview-table">
        <thead>
          <tr>
            <th>Ended</th>
            <th>Length</th>
            <th>Planned</th>
            <th>Solved</th>
            <th>Bonus XP</th>
          </tr>
        </thead>
        <tbody>
          <% interviewHistory.forEach(function(row) { %>
          <tr>
            <td><%= new Date(row.endedAt).toLocaleString() %></td>
            <td><%= row.durationMinutes %> min</td>
            <td><%= row.plannedCount %></td>
            <td><%= row.solvedCount %></td>
            <td>+<%= row.bonusXp %></td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </section>
    <% } %>
    <section class="time-by-day local-section">
      <h2 class="subsection">Time & solved by day</h2>
      <% if (typeof statsByDaySorted !== 'undefined' && statsByDaySorted.length > 0) { %>
      <% statsByDaySorted.forEach(function(day) { %>
      <div class="time-day-row">
        <span class="time-day-date"><%= day.date %></span>
        <div class="time-day-bar-wrap">
          <div class="time-day-bar" style="width: <%= Math.round((day.totalMinutes / timeChartMaxMinutes) * 100) %>%"></div>
        </div>
        <span class="time-day-mins"><%= day.totalDurationLabel %></span>
        <span class="time-day-solved"><%= day.solvedCount %> solved</span>
      </div>
      <% if (day.breakdown.length > 0) { %>
      <details class="time-day-breakdown">
        <summary>Problems &amp; time</summary>
        <ul>
          <% day.breakdown.forEach(function(b) { %>
          <li><%= b.title %> — <%= b.durationLabel %><% if (typeof b.timeNote !== 'undefined' && b.timeNote) { %> <span class="time-note">(<%= b.timeNote %>)</span><% } %></li>
          <% }); %>
        </ul>
      </details>
      <% } %>
      <% }); %>
      <% } else { %>
      <p style="color: var(--text-muted); font-size: 13px; margin: 0;">No data yet. Mark problems as solved and let the timer run to track time per day.</p>
      <% } %>
      <% if (typeof statsCacheHint !== 'undefined' && statsCacheHint) { %>
      <p class="stats-cache-hint"><%= statsCacheHint %></p>
      <% } %>
    </section>
  </body>
</html>
