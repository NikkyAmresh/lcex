<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= id %>. <%= title %></title>
    <style>
      :root {
        --bg: #1e1e1e;
        --bg-secondary: #252526;
        --text: #e5e5e5;
        --text-muted: #9d9d9d;
        --accent: #FFA116;
        --easy: #26a641;
        --medium: #d39b00;
        --hard: #dc3545;
        --code-bg: #2d2d2d;
        --border: #3c3c3c;
      }
      body {
        margin: 0;
        padding: 0 24px 24px;
        font-family: var(--vscode-font-family, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif);
        font-size: 14px;
        line-height: 1.6;
        background: var(--bg);
        color: var(--text);
      }
      .header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
        margin-bottom: 12px;
        flex-wrap: wrap;
      }
      .title {
        font-size: 28px;
        font-weight: 600;
        margin: 0;
        color: var(--text);
      }
      .solved-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        color: var(--easy);
        font-size: 14px;
        font-weight: 500;
        flex-shrink: 0;
      }
      .solved-badge svg {
        width: 18px;
        height: 18px;
      }
      .timer-row {
        display: flex;
        align-items: center;
        gap: 8px;
      }
      .timer {
        font-variant-numeric: tabular-nums;
        font-size: 18px;
        color: var(--text-muted);
        min-width: 4ch;
      }
      .timer.timer-paused { opacity: 0.7; }
      .timer-btn {
        font-size: 12px;
        padding: 4px 8px;
        border: 1px solid var(--border);
        background: var(--bg-secondary);
        color: var(--text-muted);
        border-radius: 4px;
        cursor: pointer;
        font-family: inherit;
      }
      .timer-btn:hover { opacity: 0.9; }
      .tags {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-bottom: 20px;
      }
      .tag {
        padding: 4px 12px;
        border-radius: 16px;
        font-size: 12px;
        font-weight: 500;
        border: none;
        cursor: default;
      }
      .tag.difficulty-easy { background: var(--easy); color: #fff; }
      .tag.difficulty-medium { background: var(--medium); color: #1a1a1a; }
      .tag.difficulty-hard { background: var(--hard); color: #fff; }
      .tag.difficulty-unknown { background: var(--code-bg); color: var(--text-muted); }
      .tag.extra { background: var(--code-bg); color: var(--text-muted); }
      .buttons {
        display: flex;
        gap: 10px;
        margin-bottom: 24px;
        flex-wrap: wrap;
      }
      .btn {
        font-size: 14px;
        padding: 8px 20px;
        border: none;
        cursor: pointer;
        font-weight: 500;
        border-radius: 6px;
        font-family: inherit;
      }
      .btn.solve { background: var(--accent); color: #000; }
      .btn.run { background: var(--bg-secondary); color: var(--text); border: 1px solid var(--border); }
      .btn.submit { background: var(--accent); color: #000; }
      .btn.interview-solve {
        background: rgba(255, 161, 22, 0.2);
        color: var(--accent);
        border: 1px solid var(--accent);
      }
      .btn:hover { opacity: 0.9; }
      .content {
        line-height: 1.7;
        color: var(--text);
      }
      .content p, .content li { margin: 8px 0; }
      .content code {
        background: var(--code-bg);
        padding: 2px 8px;
        border-radius: 4px;
        font-size: 13px;
        font-family: var(--vscode-editor-font-family, monospace);
      }
      .content pre {
        background: var(--code-bg);
        padding: 16px;
        border-radius: 8px;
        overflow-x: auto;
        font-size: 13px;
        line-height: 1.5;
        border: 1px solid var(--border);
      }
      .content pre code { padding: 0; background: none; }
      .content strong { color: var(--text); }
      .content h3, .content h4 { margin: 20px 0 10px; color: var(--text); }
      .solution-code-wrap pre.shiki {
        margin: 0;
        padding: 12px 16px;
        font-family: var(--vscode-editor-font-family, monospace);
        font-size: 13px;
        overflow-x: auto;
      }
      .solution-code-wrap pre.shiki code {
        background-color: transparent !important;
        padding: 0 !important;
      }
      .solution-code-wrap .line,
      .solution-code-wrap pre.shiki code span[style*="background"] {
        background: transparent !important;
      }
      .solution-code-wrap {
        cursor: pointer;
      }
      .solution-code-wrap:hover {
        outline: 1px solid var(--accent);
        outline-offset: -1px;
      }
      body.focus-compact .focus-chrome {
        display: none !important;
      }
      /* Solve / Run stay visible; mark-solved actions must remain usable in interview focus mode */
      body.focus-compact .buttons .btn.interview-solve,
      body.focus-compact .buttons .btn.mark-practice-solved {
        display: inline-block !important;
      }
      .interview-mode .tag.extra {
        display: none !important;
      }
      .interview-mode .interview-leetc {
        display: none !important;
      }
      .interview-mode .tags .tag[class*="difficulty-"] {
        display: none !important;
      }
    </style>
  </head>
  <body class="<%= (typeof focusCompact !== 'undefined' && focusCompact ? 'focus-compact ' : '') %><%= (typeof interviewMode !== 'undefined' && interviewMode ? 'interview-mode' : '') %>">
    <div class="header">
      <h1 class="title"><%= id %>. <%= title %></h1>
      <div class="timer-row">
        <span class="timer" id="timer">00:00</span>
        <button type="button" class="timer-btn" id="timerPause" title="Pause">Pause</button>
        <button type="button" class="timer-btn" id="timerRestart" title="Restart">Restart</button>
        <button type="button" class="timer-btn" id="focusLayoutBtn" title="Toggle compact problem chrome">Focus</button>
      </div>
      <% if (isSolved) { %>
        <span class="solved-badge">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
          Solved
        </span>
      <% } %>
    </div>
    <div class="tags focus-chrome">
      <span class="tag difficulty-<%= difficulty.toLowerCase() %>"><%= difficulty %></span>
      <span class="tag extra">Topics</span>
      <span class="tag extra">Companies</span>
      <span class="tag extra">Hint</span>
    </div>
    <div class="buttons">
      <button class="btn solve" onclick="solve()"><%= typeof hasSolution !== 'undefined' && hasSolution ? 'Open Solution' : 'Solve' %></button>
      <button class="btn run" onclick="run()">Run</button>
      <% if (isLoggedIn) { %><button class="btn run focus-chrome interview-leetc" onclick="runOnLeetCode()">Run on LeetCode</button><button class="btn submit focus-chrome interview-leetc" onclick="submit()">Submit</button><% } %>
      <% if (!isSolved) { %><button class="btn run mark-practice-solved" onclick="markAsSolved()" title="Mark this problem as solved">Mark as solved</button><% } %>
      <% if (typeof interviewMode !== "undefined" && interviewMode && typeof interviewSolvedInSession !== "undefined" && !interviewSolvedInSession) { %>
      <button class="btn interview-solve" type="button" onclick="markInterviewSolved()" title="Counts only for this interview session">Mark solved (this interview)</button>
      <% } %>
    </div>
    <% if (isLoggedIn) { %>
      <% if (isSolved && (typeof solutionHtml !== 'undefined' && solutionHtml || typeof solutionContent !== 'undefined' && solutionContent)) { %>
    <div class="solution-editor-section focus-chrome" style="margin-bottom: 16px;">
      <label class="stat-label" style="display:block; margin-bottom: 6px;">Solution</label>
      <% if (typeof solutionHtml !== 'undefined' && solutionHtml) { %>
      <div class="solution-code-wrap" style="border: 1px solid var(--border); border-radius: 6px; overflow: hidden; font-size: 13px; line-height: 1.5; max-height: 420px; overflow-y: auto;" ondblclick="solve()" title="Double-click to open solution"><%- solutionHtml %></div>
      <% } else { %>
      <textarea id="solutionEditor" readonly rows="16" style="width: 100%; box-sizing: border-box; background: var(--code-bg); color: var(--text); border: 1px solid var(--border); border-radius: 6px; padding: 8px 12px; font-family: var(--vscode-editor-font-family, monospace); font-size: 13px; line-height: 1.5; resize: vertical; tab-size: 4; cursor: pointer;" ondblclick="solve()" title="Double-click to open solution"><%- (solutionContent || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;') %></textarea>
      <% } %>
    </div>
      <% } else { %>
    <div class="custom-input-section focus-chrome" style="margin-bottom: 16px;">
      <label class="stat-label" for="customInput" style="display:block; margin-bottom: 6px;">Custom test input (for Run on LeetCode)</label>
      <textarea id="customInput" rows="3" style="width: 100%; box-sizing: border-box; background: var(--code-bg); color: var(--text); border: 1px solid var(--border); border-radius: 6px; padding: 8px; font-family: var(--vscode-editor-font-family, monospace); font-size: 13px;"><%= typeof sampleTestCase !== 'undefined' ? (sampleTestCase || '') : '' %></textarea>
    </div>
      <% } %>
    <% } %>
    <div class="content"><%- content %></div>
    <details class="focus-chrome" style="margin-top: 24px;">
      <summary style="cursor: pointer; color: var(--text-muted);">Notes</summary>
      <textarea id="notes" rows="4" style="width: 100%; box-sizing: border-box; margin-top: 8px; background: var(--code-bg); color: var(--text); border: 1px solid var(--border); border-radius: 6px; padding: 8px; font-family: inherit; font-size: 13px;"><%= typeof note !== 'undefined' ? (note || '') : '' %></textarea>
    </details>
    <script>
      const vscode = acquireVsCodeApi();
      const titleSlug = "<%= titleSlug %>";
      vscode.setState({ titleSlug });
      const timerEl = document.getElementById("timer");
      const pauseBtn = document.getElementById("timerPause");
      const restartBtn = document.getElementById("timerRestart");
      function fmt(sec) {
        const m = Math.floor(sec / 60);
        const s = sec % 60;
        return (m < 10 ? "0" : "") + m + ":" + (s < 10 ? "0" : "") + s;
      }
      function applyUiMode(focusC, interviewM) {
        document.body.classList.toggle("focus-compact", !!focusC);
        document.body.classList.toggle("interview-mode", !!interviewM);
      }
      applyUiMode(<%= typeof focusCompact !== 'undefined' && focusCompact ? 'true' : 'false' %>, <%= typeof interviewMode !== 'undefined' && interviewMode ? 'true' : 'false' %>);
      window.addEventListener("message", function (ev) {
        const msg = ev.data;
        if (msg.event === "timerUpdate") {
          timerEl.textContent = fmt(msg.elapsed);
          timerEl.classList.toggle("timer-paused", msg.paused);
          pauseBtn.textContent = msg.paused ? "Resume" : "Pause";
        } else if (msg.event === "uiMode") {
          applyUiMode(msg.focusCompact, msg.interviewMode);
        }
      });
      document.getElementById("focusLayoutBtn").addEventListener("click", function () {
        vscode.postMessage({ event: "toggleFocusCompact", titleSlug: titleSlug });
      });
      vscode.postMessage({ event: "timerReady", titleSlug });
      pauseBtn.addEventListener("click", function () {
        const isPaused = pauseBtn.textContent === "Resume";
        vscode.postMessage({ event: isPaused ? "timerResume" : "timerPause", titleSlug });
      });
      restartBtn.addEventListener("click", function () {
        vscode.postMessage({ event: "timerRestart", titleSlug });
      });
      function solve() { vscode.postMessage({ event: "solve", titleSlug }); }
      function run() { vscode.postMessage({ event: "run", titleSlug }); }
      function runOnLeetCode() {
        var el = document.getElementById("customInput");
        vscode.postMessage({ event: "runOnLeetCode", titleSlug, customInput: el ? el.value : "" });
      }
      function submit() { vscode.postMessage({ event: "submit", titleSlug }); }
      function markAsSolved() { vscode.postMessage({ event: "markAsSolved", titleSlug }); }
      function markInterviewSolved() { vscode.postMessage({ event: "markInterviewSolved", titleSlug }); }
      (function () {
        var notesEl = document.getElementById("notes");
        if (!notesEl) return;
        var debounce;
        notesEl.addEventListener("input", function () {
          clearTimeout(debounce);
          debounce = setTimeout(function () {
            vscode.postMessage({ event: "saveNote", titleSlug: titleSlug, note: notesEl.value });
          }, 400);
        });
      })();
    </script>
  </body>
</html>
