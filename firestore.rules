rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /logs/{docId} {
      allow create: if true;
      allow read: if request.auth != null && request.auth.uid == 'ZzoFamfai2NiUXzmYOub8aWvlpi1';
      allow update, delete: if false;
    }

    // Per-account stats: users/<uid>/stats/<leetcodeUsername>
    // Each authenticated user can read/write only under their own uid.
    match /users/{uid}/stats/{username} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Legacy top-level collection — read-only fallback during migration.
    // Remove once all clients are on >=0.1.0 of the extension.
    match /leetcodeStats/{username} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
